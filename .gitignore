# Playwright MCP browser automation folder
.playwright-mcp/

# ── Rust build artifacts ────────────────────────────────────────────
# target/ is per-workspace, never committed. Cargo.lock IS committed
# (workspace contains binary crates).
rust/target/
**/target/
*.rs.bk

# ── Node / SPA build output ─────────────────────────────────────────
# node_modules is generated; package.json / package-lock.json ARE
# committed for the SPA (spa/), so they are intentionally NOT ignored.
node_modules/
dist/
.cache/
*.tsbuildinfo

# SPA Playwright UAT artifacts (seeded DB, screenshots, perf/console
# captures, html report, traces) — generated each run, never committed.
spa/test/uat/artifacts/
test-results/
playwright-report/

# ── Editor / OS cruft ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# AI tool configs (managed externally, not part of the repo)
.claude/
.agent/
.codebuddy/
.codex/
.continue/
.copilot/
.cursor/
.gemini/
.kiro/
.opencode/
.qoder/
.roo/
.trae/
.windsurf/

# ═══════════════════════════════════════════════════════════════════
# Runtime data files — NEVER commit. These are produced on-device and
# contain user trip data, location history, OAuth tokens, etc. They
# must never appear in git history or on GitHub.
#
# Equally important: an untracked data file gets swept into a
# `git stash -u` during deploy, which has caused production data loss
# before. Keep this list comprehensive so `git stash`, `git clean`,
# and `git add .` all skip them.
# ═══════════════════════════════════════════════════════════════════

# USB disk image / backing store (large, device-specific, not source)
*.img
*.img.*

# SQLite databases (live + journals + backups/recovery copies)
*.db
*.db-shm
*.db-wal
*.db-journal
*.db.*

# Runtime state / status files
state.txt
*.log
fsck_status.json
fsck_history.json
cleanup_config.json
archive_lost_dismissed.json

# Captured media / dashcam clips
*.wav
*.mp3
*.mp4
# …except the committed SMPTE test-pattern MP4 the SPA event-player UAT streams
# (webd /stream needs a real archive file on disk — see spa/test/uat/global-setup.ts).
!spa/test/fixtures/*.mp4

# Crypto material / secrets
tesla_salt.bin
*.key
*.pem
*.crt
*.p12
secrets.*
credentials.*
*.env
.env
.env.*

# Operator config that may carry secrets / timestamped backups
config.local.*
config.yaml.bak.*

# Task 7.2 release build output (binaries, staged trees, tarballs)
release/.build/
