# TeslaUSB B-1 web app — sample configuration.
#
# Install path (matches Phase 6 setup.sh and the gunicorn unit):
#   /etc/teslausb/teslausb-web.toml
#
# Every key shown below is OPTIONAL — omit a key to fall back to
# the default baked into ``teslausb_web.config``. The values shown
# here ARE the defaults except where called out.
#
# Charter §"No shortcuts": validation runs at load time. A malformed
# value causes the gunicorn worker to fail to start with a path-
# anchored error in journalctl. There is no silent fall-through to
# defaults for misconfigured keys.

[web]
# Bind address for gunicorn. Use 127.0.0.1 when nginx is the only
# upstream (the production layout), 0.0.0.0 only if you need to
# reach gunicorn directly from another host.
host = "127.0.0.1"

# Port the Flask app listens on **when nginx is not in front**
# (developer-laptop / pytest scenarios). The production layout
# uses gunicorn on a Unix socket (see config/gunicorn.conf.py)
# and nginx terminates port 80 publicly — so this value is not
# used in a normal Pi install. Default 80 keeps direct-bind
# parity with v1 (which ran Flask as root on port 80).
port = 80

# Flask session signing key. MUST be set in production — leave
# empty for tests only. setup.sh writes a fresh 64-char hex key
# on first install. To rotate, edit this and restart gunicorn.
secret_key = "CHANGE-ME-ON-INSTALL"

# Hard cap on a single upload request body, in MiB. Larger requests
# get a clean 413 before Flask reads the body, so a malicious or
# accidental 8 GiB upload cannot exhaust the Pi Zero 2 W's 512 MiB
# of RAM. 512 MiB is the v1 default.
max_upload_mb = 512

# Memory-buffered chunk size, in MiB. The full upload is streamed
# to a tmpfile when it exceeds this, so a Light Show ZIP larger
# than this still works without OOMing. Must be <= max_upload_mb.
max_chunk_mb = 64

[paths]
# Root of the Tesla-facing backing tree. Tesla writes RecentClips /
# SavedClips / SentryClips under `<backing_root>/TeslaCam/`, which the
# teslafat daemon presents as the exFAT USB LUN. Free-space probes,
# storage-writable probes, and the video service all derive from this
# single root, so keep it pointed at the parent of the `TeslaCam/`
# directory the LUN exposes (NOT the parent of `teslacam/` + `media/`).
backing_root = "/srv/teslausb/teslacam"

# SQLite index built by `teslausb-worker`. Read-only from the
# web app's perspective.
db_path = "/var/lib/teslausb/index.sqlite3"

# Unix domain socket where `teslausb-worker` listens for IPC
# requests (status, retention policy updates, force cache
# invalidate). Created with mode 0660 owned by `teslausb:teslausb`.
ipc_socket = "/run/teslausb/worker.sock"

# Path the cache-invalidation Python service shells out to. Must
# match the trailing argv pinned in the sudoers fragment at
# /etc/sudoers.d/teslausb-cache-invalidate (Phase 4c.2).
cache_invalidate_script = "/usr/local/bin/tesla_cache_invalidate.sh"

# Root-owned helper the web shells out to (via `sudo -n`) ONLY when a
# direct clip delete fails with EACCES. Tesla / the Rust materializer
# create per-event clip dirs as teslausb:teslausb mode 0755, so the web
# user `pi` cannot rmtree them. The helper re-validates the path is a
# real TeslaCam clip directory before removing it. Must match the argv
# pinned in the sudoers fragment /etc/sudoers.d/teslausb-b1.
delete_clip_script = "/usr/local/bin/teslausb_delete_clip.sh"

# nginx X-Accel-Redirect prefix for serving video clips directly via
# nginx instead of streaming through the single sync gunicorn worker.
# When set, /videos/stream/, /videos/sei/, and /videos/download/
# return a small response with `X-Accel-Redirect: <prefix>/<path>`;
# nginx then serves the file with native Range support and zero-copy
# sendfile, freeing the worker immediately. Without this, the HTML5
# <video> element's parallel Range requests (start of file + moov
# atom at end-of-file for Tesla MP4s) serialize behind the lone
# worker and the player hangs on the loading spinner.
#
# Must match the matching `internal` location in
# /etc/nginx/sites-available/teslausb (see config/nginx-teslausb.conf).
# Set to "" to disable (dev / tests without nginx).
x_accel_redirect_prefix = "/_protected_teslacam"

[features]
# Music browsing UI. Disabled by default to match v1; users can
# flip this in Settings. When false the /media/music page returns
# 404 and the nav tab is hidden.
music_enabled = false

# Boombox (5-file alphabetical cap) browsing UI. Same gating
# as music_enabled.
boombox_enabled = false

# Samba (SMB1/SMB2) network sharing. When true the `smbd` and
# `nmbd` services run and the `/srv/teslausb/teslacam/TeslaCam`
# and `/srv/teslausb/media` paths are shared RW to the local
# network. When false the services are stopped and no SMB
# exposure exists. The Settings → Network Sharing toggle flips
# this at runtime; this key is the initial state at boot.
samba_enabled = false

# Cloud archive (rclone-backed) sync UI. Enabled by default —
# matches v1. Set to false on devices that should never push
# clips offsite.
cloud_archive_enabled = true

# Backend IPC management daemon. When true, the System Health card
# expects a daemon listening on `paths.ipc_socket` and flags a
# missing/unreachable socket as RED. When false (the B-1 default
# today — the in-tree IPC server is a phase-7 deliverable), the
# daemon block reports a green "Disabled" so the nav-bar dot is
# not noisy. Flip to true ONLY after deploying a daemon that
# actually serves the JSON envelope protocol on `paths.ipc_socket`.
ipc_daemon_enabled = false

[samba]
# Samba daemon + watcher configuration. All keys are optional.
# When the [samba] section is omitted entirely, every value below
# falls back to its built-in default (see teslausb_web.config).
#
# When no `shares = [...]` table-array is configured, two default
# shares are exposed: TeslaCam (rooted at `<backing_root>/TeslaCam`)
# and Media (rooted at `<media_root>`). Both are user-authenticated
# (no guest access) and read+write. The Linux user mapped to the
# Samba TDB entry is set by `password_username` below.
#
# On the Pi the web app runs as the unprivileged `pi` user, but
# `systemctl start smbd`, `smbpasswd -a`, and `pdbedit -L` all need
# root. `sudo_prefix` is prepended to every subprocess invocation;
# `pi` already has NOPASSWD: ALL via /etc/sudoers.d/010_pi-nopasswd.
sudo_prefix = ["sudo", "-n"]
password_username = "pi"
