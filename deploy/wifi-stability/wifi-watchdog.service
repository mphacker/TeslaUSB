# /etc/systemd/system/wifi-watchdog.service
#
# Oneshot wrapper around /usr/local/sbin/wifi-watchdog.sh, driven
# by wifi-watchdog.timer. Each timer tick fires this service, which
# runs one iteration of the escalation ladder and exits.
#
# Installed by setup-lib/12-wifi-stability.sh.

[Unit]
Description=TeslaUSB WiFi watchdog (BCM43436 SDIO lockup recovery)
Documentation=https://github.com/mphacker/TeslaUSB
After=NetworkManager.service
Wants=NetworkManager.service

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/wifi-watchdog.sh

# A wedged tick must never run forever. Type=oneshot defaults to an
# INFINITE start timeout, which is exactly how the 2026-05-28 hard
# SDIO wedge froze the ladder: the tier-4 unbind blocked, the script
# held its flock, the service never went inactive, and the timer
# (OnUnitActiveSec) therefore never re-fired. TimeoutStartSec makes
# systemd reap a killable hang so the timer re-fires. A true D-state
# hang can't be killed even by SIGKILL — that case is covered by the
# independent safe-reboot dead-man the script arms at tier 4.
TimeoutStartSec=90

# The watchdog itself must never be the thing that gets OOM-killed.
OOMScoreAdjust=-900

# Never starve the watchdog of CPU.
Nice=-5
IOSchedulingClass=realtime
IOSchedulingPriority=4

# Lock the script down — it only needs to ping, run nmcli/modprobe/
# ip, and write /run/teslausb/. No need for network sockets it
# doesn't open itself, no need for full filesystem write access.
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/run/teslausb /run/log
PrivateTmp=yes
NoNewPrivileges=no
# (NoNewPrivileges must be 'no' because modprobe + nmcli need
# their setuid/cap paths.)

[Install]
WantedBy=multi-user.target
